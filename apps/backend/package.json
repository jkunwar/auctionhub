{
  "name": "@auctionhub/backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "dotenv -e ../../.env -- ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@auctionhub/database": "workspace:*",
    "@fastify/env": "^7.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "fastify": "^5.8.5",
    "fastify-plugin": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "dotenv-cli": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.8"
  }
}
