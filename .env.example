# AuctionHub Nepal — Environment Variables
#
# Copy this file to .env and fill in every value before running the project.
#   cp .env.example .env
#

# PostgreSQL
# docker-compose maps Postgres to host port 5434 (not 5432) to avoid conflicts
# with any locally installed Postgres instance.
POSTGRES_USER=auctionhub_user
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=auctionhub_db

# Prisma reads this to connect to the database.
# Port must match the host-side mapping in docker-compose.yml (5434).
DATABASE_URL="postgresql://auctionhub_user:your_password_here@localhost:5434/auctionhub_db"

# Redis
REDIS_URL="redis://localhost:6379"

# Backend (Fastify)
PORT=3001
NODE_ENV=development

# JWT secrets — must be at least 32 characters.
# Generate a secure value with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string_min_32_chars
EMAIL_VERIFY_SECRET=replace_with_a_different_long_random_string


# Frontend (Next.js)
# Must be prefixed with NEXT_PUBLIC_ to be available in the browser.
NEXT_PUBLIC_API_URL=http://localhost:3001


# Supabase Storage ─
# Used for listing image uploads only. Get these from:
#   Supabase Dashboard → Project Settings → API
#
# SUPABASE_URL is also used to construct public image URLs on the frontend.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key


# Email (Resend) ───
# Sign up at https://resend.com — free tier is enough for development.
# FROM_EMAIL must be a verified domain in your Resend account.
# For local dev you can use the Resend test mode (no real emails sent).
RESEND_API_KEY=re_your_resend_api_key
FROM_EMAIL=noreply@yourdomain.com
