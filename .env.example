# Database
# Postgres connection string (used by Prisma)
DATABASE_URL="postgresql://auctionhub_user:your_password@localhost:5432/auctionhub_db"

# Postgres container settings (used by docker-compose)
POSTGRES_USER=auctionhub_user
POSTGRES_PASSWORD=your_password
POSTGRES_DB=auctionhub_db

# Redis
REDIS_URL="redis://localhost:6379"

# Backend (Fastify)
PORT=3001
NODE_ENV=development

# JWT secrets — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string
EMAIL_VERIFY_SECRET=replace_with_a_different_long_random_string

# ── Frontend (Next.js)
# Must start with NEXT_PUBLIC_ to be available in the browser
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Supabase (Storage)
# Get these from your Supabase project settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Email (Resend)
RESEND_API_KEY=re_your_resend_api_key
FROM_EMAIL=noreply@yourdomain.com